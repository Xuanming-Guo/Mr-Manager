{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Narrow permissions for the trusted Mr Manager main window",
  "local": true,
  "windows": ["main"],
  "platforms": ["windows"],
  "permissions": [
    "core:default",
    "allow-list-background-tasks",
    "allow-get-background-task",
    "allow-cancel-background-task",
    "allow-get-overview-snapshot",
    "allow-get-system-snapshot",
    "allow-get-system-diagnostics-snapshot",
    "allow-list-processes",
    "allow-list-ports",
    "allow-list-integrations",
    "allow-probe-integration",
    "allow-get-ollama-status",
    "allow-get-wsl-status",
    "allow-get-network-snapshot",
    "allow-run-network-diagnostic",
    "allow-start-internet-test-task",
    "allow-start-metric-recording",
    "allow-add-metric-annotation",
    "allow-stop-metric-recording",
    "allow-list-metric-sessions",
    "allow-get-metric-recording",
    "allow-export-metric-recording",
    "allow-delete-metric-recording",
    "allow-scan-cleanup-candidates",
    "allow-start-cleanup-scan-task",
    "allow-cancel-cleanup-scan",
    "allow-create-cleanup-plan",
    "allow-execute-quarantine-plan",
    "allow-start-quarantine-task",
    "allow-list-quarantine-manifests",
    "allow-restore-quarantine-item",
    "allow-purge-quarantine-item",
    "allow-purge-quarantine-manifest",
    "allow-get-app-settings",
    "allow-update-app-settings",
    "allow-get-capability-report",
    "allow-list-projects",
    "allow-add-project",
    "allow-add-project-root",
    "allow-start-project-discovery-task",
    "allow-scan-project",
    "allow-remove-project",
    "allow-cancel-project-scan",
    "allow-update-project-metadata",
    "allow-run-project-command",
    "allow-list-managed-processes",
    "allow-get-managed-process-logs",
    "allow-stop-managed-process",
    "allow-get-topology-graph",
    "allow-get-docker-status",
    "allow-get-docker-inventory",
    "allow-list-containers",
    "allow-list-docker-networks",
    "allow-list-docker-volumes",
    "allow-get-container-logs",
    "allow-container-action",
    "allow-list-compose-projects",
    "allow-parse-compose-project",
    "allow-run-compose-doctor",
    "allow-open-local-preview",
    "dialog:allow-open"
  ]
}
