{
  "name": "mr-manager",
  "private": true,
  "version": "0.1.0",
  "description": "Local-first Windows developer command center",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xuanming-Guo/Mr-Manager.git"
  },
  "homepage": "https://github.com/Xuanming-Guo/Mr-Manager#readme",
  "bugs": {
    "url": "https://github.com/Xuanming-Guo/Mr-Manager/issues"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=10"
  },
  "packageManager": "npm@11.9.0",
  "type": "module",
  "scripts": {
    "app": "tauri dev",
    "app:build": "tauri build -- --no-bundle",
    "app:open": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/open-built-app.ps1",
    "dev": "vite --port 1420 --strictPort",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "repo:check": "node scripts/check-repository-hygiene.mjs",
    "branch:check": "node scripts/check-branch-name.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run repo:check && npm run branch:check && npm run format:check && npm run lint && npm run typecheck && npm run test:run"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.20",
    "@radix-ui/react-dropdown-menu": "2.1.21",
    "@radix-ui/react-progress": "1.1.13",
    "@radix-ui/react-scroll-area": "1.2.15",
    "@radix-ui/react-tabs": "1.1.18",
    "@radix-ui/react-tooltip": "1.2.13",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-virtual": "3.14.6",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-dialog": "2.7.2",
    "@xyflow/react": "12.11.2",
    "clsx": "2.1.1",
    "lucide-react": "1.25.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-qr-code": "2.2.0",
    "react-router-dom": "7.18.1",
    "tailwind-merge": "3.6.0",
    "uplot": "1.6.32",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.3.3",
    "@tauri-apps/cli": "2.11.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.1",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
